# ===================================
# Discord Bot Configuration
# ===================================

# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application ID
DISCORD_CLIENT_ID=your_client_id_here

# Discord Client Secret (for OAuth2)
DISCORD_CLIENT_SECRET=your_client_secret_here

# Bot Owner IDs (comma-separated Discord user IDs)
# These users get access to the Owner Dashboard
OWNER_IDS=123456789012345678,987654321098765432

# ===================================
# Database Configuration
# ===================================

# PostgreSQL Connection URL
DATABASE_URL=postgresql://user:password@host:5432/discord_bot

# Redis Connection URL
REDIS_URL=redis://default:password@host:6379

# ===================================
# API Server Configuration
# ===================================

# API server port
API_PORT=3001

# JWT Secret for dashboard authentication
JWT_SECRET=your_jwt_secret_here

# Dashboard URL (for OAuth2 callback)
DASHBOARD_URL=http://localhost:3000

# API URL
API_URL=http://localhost:3001

# ===================================
# Music (Lavalink) Configuration
# ===================================

LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# ===================================
# AI Chatbot - Default Provider
# ===================================

# Default AI provider (grok, openai, claude, gemini)
DEFAULT_AI_PROVIDER=grok

# Default API key (used when server doesn't have BYOK)
DEFAULT_AI_API_KEY=your_default_ai_key_here

# ===================================
# Premium / Monetization
# ===================================

# Stripe API keys (for future monetization)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Premium check enabled (set to false for testing)
PREMIUM_ENABLED=false

# ===================================
# External Services
# ===================================

# Translation API (Google Translate / DeepL)
TRANSLATION_API_KEY=

# Imgur API (for image uploads)
IMGUR_CLIENT_ID=

# ===================================
# Logging & Debug
# ===================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Node environment
NODE_ENV=development
