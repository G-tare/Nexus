{
  "name": "nexus-bot",
  "version": "1.0.0",
  "description": "All-in-one Discord bot with 38+ modules, dashboard, and landing page",
  "type": "commonjs",
  "main": "dist/GatewayBot/src/index.js",
  "scripts": {
    "dev": "tsx watch GatewayBot/src/index.ts",
    "dev:api": "tsx watch Shared/src/api/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "build": "tsc",
    "start": "node dist/GatewayBot/src/index.js",
    "start:api": "node dist/Shared/src/api/server.js",
    "db:migrate": "tsx Shared/src/database/migrate.ts",
    "db:seed": "tsx Shared/src/database/seed.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@discordjs/rest": "^2.4.0",
    "@discordjs/voice": "^0.19.0",
    "@napi-rs/canvas": "^0.1.95",
    "@noble/ciphers": "^2.1.1",
    "@types/multer": "^2.0.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "canvas": "^2.11.2",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "discord.js": "^14.19.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.0",
    "eventemitter3": "^5.0.1",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "i18next": "^24.0.5",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "kazagumo": "^3.2.0",
    "ms": "^2.1.3",
    "multer": "^2.1.0",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "sharp": "^0.33.5",
    "shoukaku": "^4.1.0",
    "stripe": "^17.3.1",
    "uuid": "^10.0.0",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/ms": "^0.7.34",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
